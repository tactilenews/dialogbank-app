{
	"name": "dialogbank-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"sync:dependabot-secrets": "node --experimental-strip-types src/scripts/sync-dependabot-secrets.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --error-on-warnings --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "vite-node  --options.transformMode.ssr='/.*/' src/scripts/seed.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@biomejs/biome": "^2.4.7",
		"@chromatic-com/storybook": "^5.0.1",
		"@electric-sql/pglite": "^0.4.0",
		"@elevenlabs/elevenlabs-js": "^2.39.0",
		"@neondatabase/serverless": "^1.0.2",
		"@playwright/test": "^1.58.2",
		"@sentry/sveltekit": "^10.43.0",
		"@storybook/addon-a11y": "^10.2.19",
		"@storybook/addon-docs": "^10.2.19",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@storybook/addon-vitest": "^10.2.19",
		"@storybook/sveltekit": "^10.2.19",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"better-auth": "~1.5.5",
		"consola": "^3.4.2",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"drizzle-seed": "^0.3.1",
		"mdsvex": "^0.12.7",
		"playwright": "^1.58.2",
		"storybook": "^10.2.19",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vite-node": "^6.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0",
		"zod": "^4.3.6"
	}
}
