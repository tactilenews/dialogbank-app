{
	"name": "dialogbank-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"sync:dependabot-secrets": "node --experimental-strip-types src/scripts/sync-dependabot-secrets.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --error-on-warnings --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "bash ./e2e/test-e2e.sh",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"send-elevenlabs-payload": "node --experimental-strip-types src/scripts/send-elevenlabs-payload.ts",
		"db:seed": "vite-node  --options.transformMode.ssr='/.*/' src/scripts/seed.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@biomejs/biome": "^2.4.16",
		"@chromatic-com/storybook": "^5.2.1",
		"@electric-sql/pglite": "^0.5.2",
		"@elevenlabs/elevenlabs-js": "^2.52.0",
		"@neondatabase/serverless": "^1.1.0",
		"@playwright/test": "^1.61.0",
		"@sentry/sveltekit": "^10.57.0",
		"@storybook/addon-a11y": "^10.4.4",
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.4",
		"@storybook/sveltekit": "^10.4.4",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"better-auth": "~1.6.18",
		"consola": "^3.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"drizzle-seed": "^0.3.1",
		"mdsvex": "^0.12.7",
		"playwright": "^1.61.0",
		"storybook": "^10.4.4",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-node": "^6.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"zod": "^4.4.3"
	}
}
